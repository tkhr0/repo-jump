{
  "manifest_version": 3,
  "name": "Repo Jump",
  "version": "1.0.0",
  "description": "GitHub リポジトリへの高速アクセスを提供する fuzzy finder パレット",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/fuzzy.js", "content.js"],
      "css": ["style.css"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "パレットを開閉する"
    }
  }
}
